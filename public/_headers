# Security headers for Astro static site
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  # CSP with SHA-256 hashes for inline JSON-LD scripts only
  # Hashes must match dist/index.html after build validation
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-CAVFY/fCDlyeCpHs6ZvBmehGUUweCjrWSwW8/aM09LM=' 'sha256-J7N1CxMdkg9X4G79v6fY/m9pHS0C6ZmFXmiOFJ2HjAA=' 'sha256-jVNCQU78lulr82+RYhTJOjKpUQALY83jX6dA+tHusbk='; style-src 'self'; img-src 'self' data: https:; font-src 'self' data:; frame-ancestors 'none'; upgrade-insecure-requests; object-src 'none'; base-uri 'self'; form-action 'self'
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Astro build output - immutable hashed assets
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static assets with content hashes
/resume/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

# HTML files - no cache for dynamic content
/*.html
  Cache-Control: no-cache, must-revalidate, max-age=0

# SEO files - short cache
/sitemap*.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
