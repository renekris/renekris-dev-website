---
import { site } from '../../content/site';

const { contact, footer } = site;
---

<section
  id="contact"
  data-testid="contact-section"
  class="contact-section reveal-section py-20 px-6 transition-colors duration-200"
>
  <div class="max-w-2xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal-child">
      <h2
        class="contact-heading text-3xl md:text-4xl lg:text-5xl font-bold mb-6 transition-colors duration-200"
      >
        Get In Touch
      </h2>
      <p
        class="contact-availability text-lg md:text-xl mb-2 transition-colors duration-200"
      >
        {contact.availabilityText}
      </p>
    </div>

    <!-- Contact Options -->
    <div class="space-y-5 mb-12 reveal-child">
      <!-- Email Button -->
      <a
        href={`mailto:${contact.email}`}
        data-testid="contact-email"
        class="contact-btn contact-btn-primary w-full py-5 px-8 rounded-xl font-semibold flex items-center justify-center gap-3 min-h-[56px] shadow-md hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5"
      >
        <svg
          class="w-6 h-6"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        <span class="text-lg">{contact.email}</span>
      </a>

      <!-- LinkedIn Button -->
      <a
        href={contact.linkedin}
        data-testid="contact-linkedin"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-btn contact-btn-accent w-full py-5 px-8 rounded-xl font-semibold flex items-center justify-center gap-3 min-h-[56px] shadow-md hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5"
      >
        <svg
          class="w-6 h-6"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect x="2" y="9" width="4" height="12"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
        <span class="text-lg">LinkedIn Profile</span>
      </a>

      <!-- GitHub Button -->
      <a
        href={contact.github}
        data-testid="contact-github"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-btn contact-btn-contrast w-full py-5 px-8 rounded-xl font-semibold flex items-center justify-center gap-3 min-h-[56px] shadow-md hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5"
      >
        <svg
          class="w-6 h-6"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
          ></path>
        </svg>
        <span class="text-lg">GitHub Portfolio</span>
      </a>
    </div>

    <!-- Footer -->
    <footer
      class="contact-footer mt-20 pt-8 border-t text-center reveal-child"
    >
      <p
        class="contact-footer-copy text-base mb-2"
      >
        {footer.builtWithText}
      </p>
      <div
        class="contact-footer-meta flex items-center justify-center gap-2 text-sm mb-2"
      >
        <a
          href={footer.sourceUrl}
          data-testid="footer-source-link"
          target="_blank"
          rel="noopener noreferrer"
          class="source-link flex items-center gap-1 hover:opacity-70 transition-opacity"
        >
          <svg
            class="w-4 h-4"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
            ></path>
          </svg>
          <span>Source</span>
        </a>
        <span aria-hidden="true">•</span>
        <span>{footer.copyright}</span>
      </div>
    </footer>
  </div>
</section>
