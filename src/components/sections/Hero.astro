---
import { site } from '../../content/site';

const { hero, resume } = site;
---

<section
  id="hero"
  data-testid="hero-section"
  class="hero-section reveal-section"
>
  <div class="hero-content">
    <h1
      data-testid="hero-name"
      class="hero-name reveal-child"
    >
      {hero.name}
    </h1>

    <p class="hero-role reveal-child">
      {hero.role}
    </p>

    <div class="hero-tech-stack reveal-child">
      {hero.techStack.map((tech) => (
        <span class="hero-tech-badge">
          {tech}
        </span>
      ))}
    </div>

    <p class="hero-tagline reveal-child">
      {hero.tagline}
    </p>

    <p class="hero-location reveal-child">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      <span>{hero.location}</span>
    </p>

    <div class="reveal-child">
      <a
        data-testid="resume-download"
        href={resume.path}
        class="hero-resume-cta"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" x2="12" y1="15" y2="3" />
        </svg>
        <span>{resume.buttonText}</span>
      </a>
    </div>
  </div>
</section>
